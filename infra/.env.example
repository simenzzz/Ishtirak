# Copy to .env and adjust for local runs. Never commit the real .env.
POSTGRES_PASSWORD=ishtirak

# Must be >= 32 bytes. Generate each one with: openssl rand -base64 48
JWT_SECRET=replace-with-generated-local-jwt-secret
GATEWAY_SERVICE_TOKEN_SECRET=replace-with-generated-gateway-service-secret

# Optional local demo seed. Requires CORE_JAVA_PROFILES=dev and a 12+ char password.
CORE_JAVA_PROFILES=
DEMO_PASSWORD=
