# Copy to .env and adjust for local runs. Never commit the real .env.
POSTGRES_PASSWORD=ishtirak

# Must be >= 32 bytes. Generate each one with: openssl rand -base64 48
JWT_SECRET=replace-with-generated-local-jwt-secret
GATEWAY_SERVICE_TOKEN_SECRET=replace-with-generated-gateway-service-secret
GATEWAY_ANALYTICS_SERVICE_TOKEN_SECRET=replace-with-generated-gateway-analytics-secret
ANALYTICS_SERVICE_TOKEN_SECRET=replace-with-generated-analytics-service-secret
SERVICE_TOKEN_TTL_SECS=300

# Gateway browser-client (CORS + refresh cookie) settings.
# WEB_ORIGIN is the exact origin allowed to send credentialed requests.
WEB_ORIGIN=http://localhost:3000
# Emit the refresh cookie with Secure; set false only for non-localhost plain HTTP.
COOKIE_SECURE=true
# Refresh-cookie lifetime in seconds (mirrors core-java's 30-day refresh TTL).
REFRESH_COOKIE_MAX_AGE_SECS=2592000

# Optional local demo seed. Requires CORE_JAVA_PROFILES=dev and a 12+ char password.
CORE_JAVA_PROFILES=
DEMO_PASSWORD=
