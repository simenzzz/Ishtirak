{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ishtirak.dev/events/payment-received.schema.json",
  "title": "PaymentReceived",
  "description": "Emitted when a payment is recorded against an invoice.",
  "type": "object",
  "required": ["eventId", "eventType", "operatorId", "occurredAt", "payload"],
  "additionalProperties": false,
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "eventType": { "const": "payment.received" },
    "operatorId": { "type": "string", "format": "uuid" },
    "occurredAt": { "type": "string", "format": "date-time" },
    "payload": {
      "type": "object",
      "required": ["paymentId", "invoiceId", "subscriberId", "amountUsd", "method"],
      "additionalProperties": false,
      "properties": {
        "paymentId": { "type": "string", "format": "uuid" },
        "invoiceId": { "type": "string", "format": "uuid" },
        "subscriberId": { "type": "string", "format": "uuid" },
        "amountUsd": { "type": "number", "minimum": 0 },
        "method": { "type": "string", "enum": ["CASH", "WHISH"] }
      }
    }
  }
}
